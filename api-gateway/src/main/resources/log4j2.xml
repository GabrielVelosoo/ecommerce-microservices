<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <Console name="CONSOLE" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} [%X{X-Correlation-Id}] %-5p %highlight{%c}{INFO=green, WARN=yellow, ERROR=red} - %m%n"
                    disableAnsi="false"/>
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="io.github.gabrielvelosoo.apigateway" level="DEBUG" additivity="false">
            <AppenderRef ref="CONSOLE"/>
        </Logger>

        <Root level="INFO">
            <AppenderRef ref="CONSOLE"/>
        </Root>
    </Loggers>

</Configuration>
